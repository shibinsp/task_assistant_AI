# =============================================================================
# TaskPulse Backend Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Security — REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# AI Provider: mock | ollama | openai | anthropic | mistral | kimi
AI_PROVIDER=mock

# Ollama (if AI_PROVIDER=ollama)
OLLAMA_MODEL=llama3

# OpenAI (if AI_PROVIDER=openai)
# OPENAI_API_KEY=

# Anthropic (if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=

# Mistral (if AI_PROVIDER=mistral)
# MISTRAL_API_KEY=

# Kimi / Moonshot (if AI_PROVIDER=kimi)
# KIMI_API_KEY=
# KIMI_MODEL=moonshot-v1-8k

# Database (defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./taskpulse.db

# Environment: development | staging | production
ENVIRONMENT=development
